//----------------------------------------------------------------------------------
// Window: Container with scrollbar
//----------------------------------------------------------------------------------

 windowUI
 {
   spritesDef
   {
      sprite
      {
	name "cont_window"
	size 205 152
	texture "i_cont"  0 0 205 152  0 0 205 152
      }

      sprite
      {
        name "close_focus"
        size 14 14
        texture "i_ctrls" 15 76 29 90 0 0 14 14
      }

      sprite
      {
        name "close_push"
        size 14 14
        texture "i_ctrls" 15 106 29 120 0 0 14 14
      }

      sprite
      {
        name "close_normal"
        size 14 14
        texture "i_ctrls" 15 91 29 105 0 0 14 14
      }

      sprite
      {
        name "help_focus"
        size 14 14
        texture "i_ctrls" 0 76 14 90 0 0 14 14
      }

      sprite
      {
        name "help_push"
        size 14 14
        texture "i_ctrls" 0 106 14 120 0 0 14 14
      }

      sprite
      {
        name "help_normal"
        size 14 14
        texture "i_ctrls" 0 91 14 105 0 0 14 14
      }

      sprite
      {
	name "sc_polzun"
	size 24 26
	texture "i_cont"  232 38 256 64 0 0 24 26
      }

      sprite
      {
	name "sc_lbfocus"
	size 18 18
	texture "i_cont"  219 19 237 37 0 0 18 18
      }

      sprite
      {
	name "sc_lbpush"
	size 18 18
	texture "i_cont"  219 0 237 18 0 0 18 18
      }

      sprite
      {
	name "sc_lbdis"
	size 18 18
	texture "i_cont"  219 176 237 194 0 0 18 18
      }

      sprite
      {
	name "sc_rbfocus"
	size 18 18
	texture "i_cont"  238 19 256 37 0 0 18 18
      }

      sprite
      {
	name "sc_rbpush"
	size 18 18
	texture "i_cont"  238 0 256 18 0 0 18 18
      }

      sprite
      {
	name "sc_rbdis"
	size 18 18
	texture "i_cont"  238 176 256 194 0 0 18 18
      }


      sprite
      {
	name "slot_empty"
	size 36 35
	texture "i_cont"  220 66 256 101 0 0 36 35
      }

      sprite
      {
	name "slot_emptyborder"
	size 36 35
	texture "i_cont"  220 101 256 136 0 0 36 35
      }
   }

   windowName  "container_scroll"
   windowText  UISTR_WT_INVENT
   showTitle   4 -1
   drawMethod  SPRITE "cont_window"
   position    0 200
   size        205 152
   showEffect  ALPHA_IN   0.25
   hideEffect  ALPHA_OUT  0.25
   font        3
   rectTitle   10 12 170 29
   alignWin    RIGHT_X
   canDragDrop true
   textcolor   237 208 161
   escapeHandle TRUE

   control                                       // id = 1
   {
     classID    BUTTON   
     position   175 14
     size       14 14
     drawMethod SPRITE
     buttonStyle SEND_QUIT

     checkedImage     "close_push"
     focusedImage     "close_focus"
     uncheckedImage   "close_normal"

     tooltip
     {
       toolstr UISTR_CLOSEW
     }
   }

   control					// id = 2
   {
     classID	BUTTON
     position	160 14
     size	14 14
     drawMethod SPRITE
     buttonStyle SEND_HELP
     windowHelp  "language\container.hts"

     checkedImage     "help_push"
     focusedImage     "help_focus"
     uncheckedImage   "help_normal"

     tooltip
     {
       toolstr UISTR_HELP
     }
   }

   control				       // id = 3
   {
     classID LISTITEM
//     position 17 35
//     size     155 102
     position 17 32
     size     155 108
     canDragDrop true

     itemTemplate
     {
       size 150 36
       drawMethod NONE
       canDragDrop true

       control
       {
	 classID    SLOT
	 position   0 0
	 size	    36 35

	 slotfull   "slot_empty"
	 slotempty  "slot_empty"
         slotborder "slot_emptyborder"
        }

       control
       {
	 classID    SLOT
	 position   38 0
	 size	    36 35

	 slotfull   "slot_empty"
	 slotempty  "slot_empty"
         slotborder "slot_emptyborder"
       }

       control
       {
	 classID    SLOT
	 position   76 0
	 size	    36 35
	 slotfull   "slot_empty"
	 slotempty  "slot_empty"
         slotborder "slot_emptyborder"
       }

       control
       {
	 classID    SLOT
	 position   114 0
	 size	    36 35
	 slotfull   "slot_empty"
	 slotempty  "slot_empty"
         slotborder "slot_emptyborder"
       }
     }

     vscrollbar
     {
      classID	 SCROLL_BAR
//      position	 157 19
      position	 157 22
      size	 16 65
      scrollSpr  "sc_polzun" 24 26
      deltaStep  10

      leftbutton
      {
       position   -1 -18
       size	  18 18
       drawMethod SPRITE

       focusedImage "sc_lbfocus"
       checkedImage "sc_lbpush"
       disabledImage "sc_lbdis"
      }

      rightbutton
      {
       position   -1 64
       size	  18 18
       drawMethod SPRITE

       focusedImage "sc_rbfocus"
       checkedImage "sc_rbpush"
       disabledImage "sc_rbdis"
      }
    }
   }
 }


