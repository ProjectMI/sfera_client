//-----------------------------------------------------------------
// Description: birds in woods
//-----------------------------------------------------------------
soundeffect
{
   eff_number  5001
   flags SF_PLAY_RANDOMMIX | SF_PLAY_USEREGION | SF_PLAY_TIMEGROUPS
   cache_lifetime 60

   min_distance 10.0
   max_distance 50.0
   mix_duration 2.5
   region_radius 30.0 5.0 30.0

   audio_files 
   {
       source 0 "sounds\nt_day_birds1.wav"
       source 1 "sounds\nt_day_birds2.wav"
       source 2 "sounds\nt_day_birds3.wav"
       source 3 "sounds\nt_day_birds4.wav"
       source 4 "sounds\nt_day_birds5.wav"
       source 5 "silence" 1.0
       source 6 "sounds\nt_night_birds1.wav"
       source 7 "sounds\nt_night_birds2.wav"
       source 8 "sounds\nt_night_birds3.wav"
       source 9 "sounds\nt_night_birds4.wav"
       source 10 "sounds\nt_night_birds5.wav"
       source 11 "silence" 1.0
   }
   time_groups
   {
      time  6.0   19.0  0 5
      time 19.0   21.0  3 8
      time 21.0    5.0  6 11
      time  5.0    6.0  2 7
   }

}

