	size 36 35
	texture "i_cont"  220 66 256 101 0 0 36 35
      }

      sprite
      {
	name "slot_emptyred"
	size 36 35
	texture "i_cont"  220 101 256 136 0 0 36 35
      }

      sprite
      {
	name "slot_emptygrn"
	size 36 35
	texture "i_cont"  220 136 256 171 0 0 36 35
