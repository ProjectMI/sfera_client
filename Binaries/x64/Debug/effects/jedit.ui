	texture "i_help"  0 0  0   0   218 62 256 222

	texture "i_help"  0 56 256 109 0 222 256 275

	texture "i_help"  0 163 202 227  16 62 218 126
	texture "i_help"  0 163 202 227  16 126 218 190
	texture "i_help"  0 163 202 195  16 190 218 222

        tcoords 1         160 109 160 125 0 125 0 109
        tcoords 2         160 125 160 163 0 163 0 125
      }

      sprite
      {
        name "close_focus"
        size 14 14
        texture "i_ctrls" 15 76 29 90 0 0 14 14
      }

      sprite
      {
