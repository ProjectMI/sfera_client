//----------------------------------------------------------------------------------
// Window: Mantra book
//----------------------------------------------------------------------------------

 windowUI
 {
   spritesDef
   {
      sprite
      {
	name "mb_window"
	size 205 142
	texture "i_mantra"  0 0 205 142  0 0 205 142
      }

      sprite
      {
        name "close_focus"
        size 14 14
        texture "i_ctrls" 15 76 29 90 0 0 14 14
      }

      sprite
      {
        name "close_push"
        size 14 14
        texture "i_ctrls" 15 106 29 120 0 0 14 14
      }

      sprite
      {
        name "close_normal"
        size 14 14
        texture "i_ctrls" 15 91 29 105 0 0 14 14
      }

      sprite
      {
        name "help_focus"
        size 14 14
        texture "i_ctrls" 0 76 14 90 0 0 14 14
      }

      sprite
      {
        name "help_push"
        size 14 14
        texture "i_ctrls" 0 106 14 120 0 0 14 14
      }

      sprite
      {
        name "help_normal"
        size 14 14
        texture "i_ctrls" 0 91 14 105 0 0 14 14
      }

      sprite
      {
	name "sc_polzun"
	size 26 24
	texture "i_mantra"  230 0 256 24 0 0 26 24
      }

      sprite
      {
	name "sc_lbfocus"
	size 18 18
	texture "i_mantra"  211 19 229 37 0 0 18 18
      }

      sprite
      {
	name "sc_lbpush"
	size 18 18
	texture "i_mantra"  238 44 256 62 0 0 18 18
      }

      sprite
      {
	name "sc_lbdis"
	size 18 18
	texture "i_mantra"  219 38 237 56 0 0 18 18
      }

      sprite
      {
	name "sc_rbfocus"
	size 18 18
	texture "i_mantra"  211 0 229 18 0 0 18 18
      }

      sprite
      {
	name "sc_rbpush"
	size 18 18
	texture "i_mantra"  238 25 256 43 0 0 18 18
      }

      sprite
      {
	name "sc_rbdis"
	size 18 18
	texture "i_mantra"  219 57 237 75 0 0 18 18
      }

      sprite
      {
	name "slot_empty"
	size 36 35
	texture "i_cont"  220 66 256 101 0 0 36 35
      }

      sprite
      {
	name "slot_emptyborder"
	size 36 35
	texture "i_cont"  220 101 256 136 0 0 36 35
      }
   }

   windowName  "mantra_book"
   windowText  UISTR_WT_MNBK
   showTitle   3 -2
   drawMethod  SPRITE "mb_window"
   position    0 253
   size        205 142
   showEffect  ALPHA_IN   0.25
   hideEffect  ALPHA_OUT  0.25
   font        3
   rectTitle   10 12 165 29
   alignWin    RIGHT_X
   canDragDrop true
   textcolor   237 208 161
   escapeHandle TRUE

   control                                       // id = 1
   {
     classID    BUTTON   
     position   175 13
     size       14 14
     drawMethod SPRITE
     buttonStyle SEND_QUIT

     checkedImage     "close_push"
     focusedImage     "close_focus"
     uncheckedImage   "close_normal"

     tooltip
     {
       toolstr UISTR_CLOSEW
     }
   }

   control					// id = 2
   {
     classID	BUTTON
     position	160 13
     size	14 14
     drawMethod SPRITE
     buttonStyle SEND_HELP
     windowHelp  "language\mantrabook.hts"

     checkedImage     "help_push"
     focusedImage     "help_focus"
     uncheckedImage   "help_normal"

     tooltip
     {
       toolstr UISTR_HELP
     }
   }

   control				       // id = 3
   {
     classID LISTITEM
//     position 53 34
     position 48 34
//     size     142 102
     size     144 102
     canDragDrop true
     horizontal true

     itemTemplate
     {
//       size 37 72
       size 36 72
       drawMethod NONE
       canDragDrop true       

       control
       {
	 classID    SLOT
	 position   0 0
	 size	    36 35

	 slotfull   "slot_empty"
	 slotempty  "slot_empty"
         slotborder "slot_emptyborder"
       }

       control
       {
	 classID    SLOT
	 position   0 39
	 size	    36 35

	 slotfull   "slot_empty"
	 slotempty  "slot_empty"
         slotborder "slot_emptyborder"
       }
     }

     hscrollbar
     {
      classID	 SCROLL_BAR
//      position	 -20 78
      position	 -15 78
      size	 138 14
      scrollSpr  "sc_polzun" 26 24
      deltaStep  10

      leftbutton
      {
       position   -18 -1
       size	  18 18
       drawMethod SPRITE

       focusedImage "sc_lbfocus"
       checkedImage "sc_lbpush"
       disabledImage "sc_lbdis"
      }

      rightbutton
      {
       position   139 -1
       size	  18 18
       drawMethod SPRITE

       focusedImage "sc_rbfocus"
       checkedImage "sc_rbpush"
       disabledImage "sc_rbdis"
      }
    }
   }

   control
   {
     classID    IMAGE
     position   15 32
     size       35 35

     tooltip
     {
       toolstr UISTR_TT_MANT01
     }
   }

   control
   {
     classID    IMAGE
     position   15 73
     size       35 35
 
     tooltip
     {
       toolstr UISTR_TT_MANT02
     }
   }

 }
