//-----------------------------------------------------------------
// Parameters:
//-----------------------------------------------------------------
// eff_number   - номер эффекта
// min_distance - минимальная дистанция после которой звук
//                не увел. в громкости ( доходит пика ) ( метры )
// max_distance - максимальная дистанция после которой звук
                  не слышен ( в метрах )
// mix_duration - в секундах, момент когда начинается другой звук,
//                тоесть start_mix = sound_time - mix_duration
//                default: 1.0
// audio_file   - задается имя звукового файла
// audio_files  - если имеется набор звук. файлов, то он задается
//                в этом блоке
//                audio_files
//                {
//                  source 0 "sounds\file01.wav"
//                  source 1 "sounds\file02.wav"
//                  source 2 ...
//                  ...
//                }
// cache_lifetime -  время жизни звука в кэше после проигрывания
//                   в секундах. default: 5.0
//                   -1 - звук не удаляется из кэша
// flags          - флаги, можно указать несколько через |
                  - SF_PLAY_LOOPED - играть зацикленно звук
                  - SF_TYPE_ENVIRONMENT - звук не являеться 3D звуком
                  - SF_PLAY_RANDOM      - по рандому выбираеться звук
                                          из набора и играется
                  - SF_PLAY_RANDOMMIX   - звуки играються рандомно,
                                          последовательно микшируются
                                          образуя зацикленный звук
// offset_vec     - вектор сдвига относительно позиции объекта
                    в метрах (floatX,floatY,floatZ)
//--------------------------------------------------------------------

//-----------------------------------------------------------------
// Description: Fireball explosion
//-----------------------------------------------------------------
soundeffect
{
   eff_number  5000
   flags SF_PLAY_LOOPED

   min_distance 0.5
   max_distance 20.0
   audio_file "sounds\bloodlust.wav"
}

