//----------------------------------------------------------------------------------
// Window: Tournament
//----------------------------------------------------------------------------------

 windowUI
 {
   spritesDef
   {
      sprite
      {
        name "t_window"
        size 205 317
        texture "tmnt"      0 0 205 298    0 0 205 298
      }

      sprite
      {
        name "close_focus"
        size 14 14
        texture "i_ctrls" 15 76 29 90 0 0 14 14
      }

      sprite
      {
        name "close_push"
        size 14 14
        texture "i_ctrls" 15 106 29 120 0 0 14 14
      }

      sprite
      {
        name "close_normal"
        size 14 14
        texture "i_ctrls" 15 91 29 105 0 0 14 14
      }

      sprite
      {
        name "help_focus"
        size 14 14
        texture "i_ctrls" 0 76 14 90 0 0 14 14
      }

      sprite
      {
        name "help_push"
        size 14 14
        texture "i_ctrls" 0 106 14 120 0 0 14 14
      }

      sprite
      {
        name "help_normal"
        size 14 14
        texture "i_ctrls" 0 91 14 105 0 0 14 14
      }


      sprite
      {
        name "sc_polzun"
        size 24 26
        texture "tmnt"  232 38 256 64 0 0 24 26
      }

      sprite
      {
        name "sc_lbfocus"
        size 18 18
        texture "tmnt"  219 19 237 37 0 0 18 18
      }

      sprite
      {
        name "sc_lbpush"
        size 18 18
        texture "tmnt"  219 0 237 18 0 0 18 18
      }

      sprite
      {
        name "sc_lbdis"
        size 18 18
        texture "tmnt"  219 67 237 85 0 0 18 18
      }

      sprite
      {
        name "sc_rbfocus"
        size 18 18
        texture "tmnt"  238 19 256 37 0 0 18 18
      }

      sprite
      {
        name "sc_rbpush"
        size 18 18
        texture "tmnt"  238 0 256 18 0 0 18 18
      }

      sprite
      {
        name "sc_rbdis"
        size 18 18
        texture "tmnt"  238 67 256 85 0 0 18 18
      }



   }

   windowName  "tournament"
   windowText  UISTR_WC_TMNT
   showTitle   4 1
   drawMethod  SPRITE "t_window"
   position    0 50
   size        205 298
   showEffect  ALPHA_IN   0.25
   hideEffect  ALPHA_OUT  0.25
   font        3
   rectTitle   10 9 159 28
   alignWin    RIGHT_X
   textcolor   237 208 161
   escapeHandle TRUE

   control					 // id = 1
   {
     classID	BUTTON
     position	175 13
     size	14 14
     drawMethod SPRITE
     buttonStyle SEND_QUIT

     checkedImage     "close_push"
     focusedImage     "close_focus"
     uncheckedImage   "close_normal"

     tooltip
     {
       toolstr UISTR_CLOSEW
     }
   }

   control					 // id = 2
   {
     classID	BUTTON
     position	160 13
     size	14 14
     drawMethod SPRITE
     buttonStyle SEND_HELP
     windowHelp  "language\tournament.hts"

     checkedImage     "help_push"
     focusedImage     "help_focus"
     uncheckedImage   "help_normal"

     tooltip
     {
       toolstr UISTR_HELP
     }
   }
    // кнопка зарегистрироваться/отказаться
    control					 // id = 3
    {
        classID	BUTTON
        position	42 263
        size	121 17
        font	3
        focuscolor 255 239 212
        textcolor	237 208 161
        textformat CENTER_X
        windowText UISTR_WC_TMNT00
        disabledcolor 150 150 150
    }

    // список игроков
    control				       // id = 4
    {
        classID LISTITEM
        position 12 124
        size     152 123
        selectSprite "slot_name"
        canSelectItems false
        //     createItems 10

        itemTemplate
        {
            size 152 21
            drawMethod NONE

            control
            {
                classID    IMAGE
                position   2 3
                size	    15 15
                //	 image	    "clan_i05"
            }

            control
            {
                classID    TEXT
                textFormat CENTER_Y
                position   22 3
                size	    130 15
                font	    2
                //	 windowText UISTR_VINOS
            }
        }

        vscrollbar
        {
            classID	 SCROLL_BAR
            position	 164 17
            size	 16 91
            scrollSpr  "sc_polzun" 24 26
            deltaStep  10

            leftbutton
            {
                position   -1 -17
                size	  18 18
                drawMethod SPRITE

                focusedImage "sc_lbfocus"
                checkedImage "sc_lbpush"
                disabledImage "sc_lbdis"
            }

            rightbutton
            {
                position  -1 90
                size	  18 18
                drawMethod SPRITE

                focusedImage "sc_rbfocus"
                checkedImage "sc_rbpush"
                disabledImage "sc_rbdis"
            }
        }
    }
    
    // параметры турнира
