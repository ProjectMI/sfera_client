 windowUI
 {
   spritesDef
   {
      sprite
      {
	name "map_window"
	size 205 152
	texture "i_cont"  0 0 205 152  0 0 205 152
      }

      sprite
      {
	name "slot_img"
	size 151 18
	texture "i_cont"  0 245 151 254 0 0 151 9
	texture "i_cont"  0 245 151 254 0 9 151 18
        tcoords 1 0 254 151 254 151 245 0 245
      }

      sprite
      {
	name "map01"
	size 12 12
	texture "i_cont"  231 195 243 207 0 0 12 12
      }

      sprite
      {
	name "map02"
	size 12 12
	texture "i_cont"  244 208 256 220 0 0 12 12
      }

      sprite
      {
	name "map03"
	size 12 12
	texture "i_cont"  231 208 243 220 0 0 12 12
      }

      sprite
      {
	name "map04"
	size 12 12
	texture "i_cont"  244 195 256 207 0 0 12 12
      }

      sprite
      {
        name "close_focus"
        size 14 14
        texture "i_ctrls" 15 76 29 90 0 0 14 14
      }

      sprite
      {
        name "close_push"
        size 14 14
        texture "i_ctrls" 15 106 29 120 0 0 14 14
      }

      sprite
      {
        name "close_normal"
        size 14 14
        texture "i_ctrls" 15 91 29 105 0 0 14 14
      }

      sprite
      {
        name "help_focus"
        size 14 14
        texture "i_ctrls" 0 76 14 90 0 0 14 14
      }

      sprite
      {
        name "help_push"
        size 14 14
        texture "i_ctrls" 0 106 14 120 0 0 14 14
      }

      sprite
      {
        name "help_normal"
        size 14 14
        texture "i_ctrls" 0 91 14 105 0 0 14 14
      }

      sprite
      {
	name "sc_polzun"
	size 24 26
	texture "i_cont"  232 38 256 64 0 0 24 26
      }

      sprite
      {
	name "sc_lbfocus"
	size 18 18
	texture "i_cont"  219 19 237 37 0 0 18 18
      }

      sprite
      {
	name "sc_lbpush"
	size 18 18
	texture "i_cont"  219 0 237 18 0 0 18 18
      }

      sprite
      {
	name "sc_lbdis"
	size 18 18
	texture "i_cont"  219 176 237 194 0 0 18 18
