   windowName  "inventory"
   windowText  UISTR_WT_INVENT
   showTitle   3 0
   drawMethod  SPRITE "inv_window"
   position    0 50
   size        220 173
   showEffect  ALPHA_IN   0.25
   hideEffect  ALPHA_OUT  0.25
   font        3
   rectTitle   16 11 170 28
   alignWin    RIGHT_X
   canDragDrop true
   textcolor   237 208 161
   escapeHandle TRUE

   control                                       // id = 1
   {
     classID    BUTTON   
     position   180 14
     size       14 14
     drawMethod SPRITE
     buttonStyle SEND_QUIT

     checkedImage     "close_push"
     focusedImage     "close_focus"
     uncheckedImage   "close_normal"

     tooltip
