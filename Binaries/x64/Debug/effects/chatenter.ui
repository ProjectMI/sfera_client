   windowName "chatenter"
   drawMethod  SPRITE "chat_window"
   position    0 0
   size        582 36
   showEffect  ALPHA_IN   0.25
   hideEffect  ALPHA_OUT  0.25
//   hideEffect  MOVE_BOTTOM  0.25 36 36
   alignWin    RIGHT_Y
   saveLastPosition false
   canNotCross TRUE

   control					    // id = 1
   {
     classID	BUTTON
     position   4 9
     size	24 25
     drawMethod SPRITE
     uncheckedImage "b1_normal"
     checkedImage   "b1_push"
     focusedImage   "b1_focus"
   }

   control                                   // id = 2
   {
     classID HTEDIT
     position  32 13
     size      500 18
     font      4
    
     textColor       255 255 255
     cursorColor     255 255 255
     linkColor       255 255 255
     playerLinkColor 255 0   0
     itemLinkColor   0   255 0

     maxHistoryLength     256
     maxVisibleTextLength 256
     maxHyperTextLength   3072
     cursorType           vline
     editMode             enterPlainText
     visibleTextMargin    2 2 2 2
     hidden               false
   }

   tempcontrol                                          // id = 2
   {
     classID    EDIT
     position   32 13
     size       500 18
     font       4
     cursorOffset 0 -2
     maxsymbols 69
     enteredOnFocus false
   }

   control                                          // id = 3
