//----------------------------------------------------------------------------------
// Window: Alchemic book
//----------------------------------------------------------------------------------

 windowUI
 {
   spritesDef
   {
      sprite
      {
	name "mb_window"
	size 205 317
	texture "i_alchemic"  0 0 205 256  0 0 205 256
        texture "i_msg"       0 150 205 211 0 256 205 317
      }

      sprite
      {
        name "close_focus"
        size 14 14
        texture "i_ctrls" 15 76 29 90 0 0 14 14
      }

      sprite
      {
        name "close_push"
        size 14 14
        texture "i_ctrls" 15 106 29 120 0 0 14 14
      }

      sprite
      {
        name "close_normal"
        size 14 14
        texture "i_ctrls" 15 91 29 105 0 0 14 14
      }

      sprite
      {
        name "help_focus"
        size 14 14
        texture "i_ctrls" 0 76 14 90 0 0 14 14
      }

      sprite
      {
        name "help_push"
        size 14 14
        texture "i_ctrls" 0 106 14 120 0 0 14 14
      }

      sprite
      {
        name "help_normal"
        size 14 14
        texture "i_ctrls" 0 91 14 105 0 0 14 14
      }

      sprite
      {
	name "sc_polzun"
	size 26 24
	texture "i_alchemic"  230 0 256 24 0 0 26 24
      }

      sprite
      {
	name "sc_lbfocus"
	size 18 18
	texture "i_alchemic"  211 19 229 37 0 0 18 18
