      sprite
      {
	name "sc_rbpush"
	size 18 18
	texture "i_alchemic"  238 25 256 43 0 0 18 18
      }

      sprite
      {
	name "sc_rbdis"
	size 18 18
	texture "i_alchemic"  219 57 237 75 0 0 18 18
      }


      sprite
      {
	name "slot_empty"
	size 36 35
	texture "i_cont"  220 66 256 101 0 0 36 35
      }

      sprite
      {
	name "slot_emptyborder"
	size 36 35
	texture "i_cont"  220 101 256 136 0 0 36 35
      }
   }

   windowName  "alchemic_book"
   windowText  UISTR_WT_ACBK
   showTitle   3 -2
   drawMethod  SPRITE "mb_window"
   position    0 50
   size        205 317
   showEffect  ALPHA_IN   0.25
   hideEffect  ALPHA_OUT  0.25
   font        3
   rectTitle   10 12 165 29
//   alignWin    RIGHT_X
   canDragDrop true
   textcolor   237 208 161
   escapeHandle TRUE

   control                                       // id = 1
   {
     classID    BUTTON   
     position   175 13
     size       14 14
     drawMethod SPRITE
     buttonStyle SEND_QUIT

     checkedImage     "close_push"
     focusedImage     "close_focus"
     uncheckedImage   "close_normal"

     tooltip
     {
       toolstr UISTR_CLOSEW
     }
   }

   control					// id = 2
   {
     classID	BUTTON
     position	160 13
     size	14 14
     drawMethod SPRITE
     buttonStyle SEND_HELP
     windowHelp  "language\alchemicbook.hts"

     checkedImage     "help_push"
     focusedImage     "help_focus"
     uncheckedImage   "help_normal"

     tooltip
     {
       toolstr UISTR_HELP
     }
   }

   control				       // id = 3
   {
     classID LISTITEM
     position 45 36
     size     150 251
     canDragDrop true
//     createItems 10
     horizontal true

     itemTemplate
     {
       size 37 251
       drawMethod NONE
       canDragDrop true       

       control
       {
	 classID    SLOT
	 position   0 0
	 size	    36 35

	 slotfull   "slot_empty"
	 slotempty  "slot_empty"
         slotborder "slot_emptyborder"
       }

       control
       {
	 classID    SLOT
	 position   0 41
	 size	    36 35

	 slotfull   "slot_empty"
	 slotempty  "slot_empty"
         slotborder "slot_emptyborder"
       }

       control
       {
	 classID    SLOT
	 position   0 76
	 size	    36 35

	 slotfull   "slot_empty"
	 slotempty  "slot_empty"
         slotborder "slot_emptyborder"
       }

       control
       {
	 classID    SLOT
	 position   0 111
	 size	    36 35

	 slotfull   "slot_empty"
	 slotempty  "slot_empty"
         slotborder "slot_emptyborder"
       }

       control
       {
	 classID    SLOT
	 position   0 146
	 size	    36 35

	 slotfull   "slot_empty"
	 slotempty  "slot_empty"
         slotborder "slot_emptyborder"
       }

       control
       {
	 classID    SLOT
	 position   0 181
	 size	    36 35

	 slotfull   "slot_empty"
	 slotempty  "slot_empty"
         slotborder "slot_emptyborder"
       }

       control
       {
	 classID    SLOT
	 position   0 216
	 size	    36 35

	 slotfull   "slot_empty"
	 slotempty  "slot_empty"
         slotborder "slot_emptyborder"
       }
     }

     hscrollbar
     {
      classID	 SCROLL_BAR
      position	 -14 256
      size	 140 14
      scrollSpr  "sc_polzun" 26 24
      deltaStep  10

      leftbutton
      {
       position   -18 -2
       size	  18 18
       drawMethod SPRITE

       focusedImage "sc_lbfocus"
       checkedImage "sc_lbpush"
       disabledImage "sc_lbdis"
      }

      rightbutton
      {
       position   141 -2
       size	  18 18
       drawMethod SPRITE

       focusedImage "sc_rbfocus"
       checkedImage "sc_rbpush"
       disabledImage "sc_rbdis"
      }
    }
   }
