   windowName  "newclan"
   windowText  UISTR_WT_CLAN
   showTitle   4 0
   drawMethod  SPRITE "c_window"
   position    0 45
   size        205 179
   showEffect  ALPHA_IN   0.25
   hideEffect  ALPHA_OUT  0.25
   font        3
   rectTitle   10 12 165 29
   alignWin    RIGHT_X
   textcolor   237 208 161
   escapeHandle TRUE

   control                                       // id = 1
   {
     classID    BUTTON   
     position   175 14
     size       14 14
     drawMethod SPRITE
     buttonStyle SEND_QUIT

