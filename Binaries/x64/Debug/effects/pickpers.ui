 windowUI
 {
   spritesDef
   {
      sprite
      {
	name "window"
	size 394 404
	texture "i_pick01"    0 0 256 256    0 0 256 256
        texture "i_pick02"    0 0 256 148    0 256 256 404
        texture "i_pick02"    0 148 138 256  256 0 394 108

        texture "i_pick03"    0 0 0 0  256 364 394 404
        texture "i_pick03"    0 0  138 256   256 108 394 364

        tcoords 3         256 0 256 138 216 138 216 0
      }


      sprite
      {
        name "help_focus"
        size 14 14
        texture "i_ctrls" 0 76 14 90 0 0 14 14
      }

      sprite
      {
        name "help_push"
        size 14 14
        texture "i_ctrls" 0 106 14 120 0 0 14 14
      }

      sprite
      {
        name "help_normal"
        size 14 14
        texture "i_ctrls" 0 91 14 105 0 0 14 14
      }

      sprite
      {
        name "spin"
        size 37 26
        texture "i_map"  103 120 140 146 0 0 37 26
      }


      sprite
      {
        name "sl_focus"
        size 18 18
        texture "i_ctrls" 0 19 18 37 0 0 18 18
      }

      sprite
      {
        name "sl_normal"
        size 18 18
        texture "i_ctrls" 0 0 18 18 0 0 18 18
      }

      sprite
      {
        name "sl_push"
        size 18 18
        texture "i_ctrls" 0 38 18 56 0 0 18 18
      }

      sprite
      {
        name "sl_disabled"
        size 18 18
        texture "i_ctrls" 0 57 18 75 0 0 18 18
      }

      sprite
      {
        name "sr_focus"
        size 18 18
        texture "i_ctrls" 19 19 37 37 0 0 18 18
      }

      sprite
      {
        name "sr_push"
        size 18 18
        texture "i_ctrls" 19 38 37 56 0 0 18 18
      }

      sprite
      {
        name "sr_disabled"
        size 18 18
        texture "i_ctrls" 19 57 37 75 0 0 18 18
      }

      sprite
      {
        name "sr_normal"
        size 18 18
        texture "i_ctrls" 19 0 37 18 0 0 18 18
      }


      sprite
      {
	name "check_mark"
	size 125 7
	texture "i_miss" 208 0 215 7 0 0 7 7
	texture "i_miss" 208 0 215 7 118 0 125 7
      }
   }

   windowName  "pick_person"
   windowText  UISTR_WT_CPS01
   showTitle   3 0
   drawMethod  SPRITE "window"
   position    -20 20
   size        394 404
   showEffect  ALPHA_IN   0.25
   hideEffect  ALPHA_OUT  0.25
   font        3
   rectTitle   10 10 360 29
   textcolor   237 208 161
   alignWin    RIGHT_X
   saveLastPosition false
   canNotCross TRUE   

