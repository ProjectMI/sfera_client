   control                                   // id = 4
   {
    classID Button
    position  20 80
    size      130 20
    font      3
    textcolor 237 208 160 255
    disabledcolor 128 128 128 255
    windowText UISTR_INV_GET_ALL
    textFormat  CENTER
    drawMethod SPRITE
    focuscolor 255 239 213
hidden true
