//----------------------------------------------------------------------------------
// Window: Delete Character
//----------------------------------------------------------------------------------

 windowUI
 {
   spritesDef
   {
     sprite
     {
      name "window"
      size 210 210

      texture "i_journal"  0 90 40 144    0 0 40 54     // Верхний левый угол
      texture "i_journal"  62 90 196 144  40 0 174 54   // Верхний средняя часть
      texture "i_journal"  39 90 0 144    174 0 213 54  // Верхний правый угол

      texture "i_help"  121 125 121 109  0 54 16 84     // Средняя левая часть
      texture "i_help"  0 163 181 226    16 54 197 84   // Средняя средняя часть
      texture "i_help"  121 109 121 125  197 54 213 84  // Средняя правая часть

      texture "i_help"  0 56 40 109    0 84 40 137      // Нижний левый угол
      texture "i_help"  62 56 196 109  40 84 174 137    // Нижняя средняя часть
      texture "i_help"  39 56 0 109    174 84 213 137   // нижний правый угол

      texture "i_journal" 0 75 60 89  47 82 107 96      // Фон для поля ввода
      texture "i_journal" 60 75 0 89  107 82 167 96

      tcoords 3 121 109 121 125 91 125 91 109
      tcoords 5 121 125 121 109 91 109 91 125
     }

     sprite
     {
      name "ok_normal"
      size 32 24
      texture "i_ctrls" 63 0 95 24  0 0 32 24
     }

     sprite
     {
      name "ok_focus"
      size 32 24
      texture "i_ctrls" 96 0 128 24  0 0 32 24
     }

     sprite
     {
      name "ok_push"
      size 32 24
      texture "i_ctrls" 96 50 128 74  0 0 32 24
     }

     sprite
     {
      name "close_normal"
      size 14 14
      texture "i_invent" 242 227 256 241  0 0 14 14
     }

     sprite
     {
      name "close_focus"
      size 14 14
      texture "i_invent" 242 212 256 226  0 0 14 14
     }

     sprite
     {
      name "close_push"
      size 14 14
      texture "i_invent" 242 242 256 256  0 0 14 14
     }

     sprite
     {
      name "help_focus"
      size 14 14
      texture "i_invent" 227 212 241 226  0 0 14 14
     }

     sprite
     {
      name "help_normal"
      size 14 14
      texture "i_invent" 227 227 241 241  0 0 14 14
     }

     sprite
     {
      name "help_push"
      size 14 14
      texture "i_invent" 227 242 241 256  0 0 14 14
     }     
   }

   windowName "del_char_window"
   windowText UISTR_WT_DEL_CHAR
   drawMethod SPRITE "window"
   showTitle 3 0
   position  0 0
   size 210 210
   font 3
   rectTitle 10 10 255 29
   showEffect ALPHA_IN 0.2500 0.0000 0.0000
   hideEffect ALPHA_OUT 0.2500 0.0000 0.0000
   textcolor 237 208 161 255
   alignWin CENTER_X | CENTER_Y
   escapeHandle TRUE
   canNotCross TRUE

   control                                   // id = 1
   {
     classID     BUTTON
     position    186 13
     size        14 14
     drawMethod  SPRITE
     buttonStyle SEND_QUIT

     checkedImage   "close_push"
     focusedImage   "close_focus"
     uncheckedImage "close_normal"

     tooltip
     {
       toolstr UISTR_CLOSEW
     }
   }

   control                                   // id = 2
   {
     classID	 BUTTON
     position	 170 13
     size        14 14
     drawMethod  SPRITE
     buttonStyle SEND_HELP
     windowHelp  "language\trade.hts"

     checkedImage   "help_push"
     focusedImage   "help_focus"
     uncheckedImage "help_normal"

     tooltip
     {
       toolstr UISTR_HELP
     }

     hidden true
   }

   control                                   // id = 3
   {
     classID    HYPER_TEXT
     position   28 30
     size       160 80
     font       2
     textformat CENTER
     linkcolor  FFEDD0A1 FFFFEFD4
     hyperText  "Language\delete_character.hts"
   }
 
   control                                   // id = 4
   {
    classID        EDIT
    position       49 84
    size           113 11
    font           2
    textcolor      237 208 161 255
    disabledcolor  128 128 128 255
    textFormat     CENTER
    maxsymbols     20
    enteredOnFocus false
   }

   control                                   // id = 5
   {
    classID        BUTTON
    position       57 102
    size           100 20
    font           3
    textcolor      255 255 255 255
    disabledcolor  128 128 128 255
    drawMethod     SPRITE
    textFormat     CENTER
    focuscolor     255 239 212
    windowText     UISTR_BT_DEL_CHAR
    hotKey "ENTER" 0 0 0
   }
 }
