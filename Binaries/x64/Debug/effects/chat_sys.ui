//----------------------------------------------------------------------------------
// Window: Chat system messages
//----------------------------------------------------------------------------------

 windowUI
 {
   spritesDef
   {
      sprite
      {
	name "cont_window"
	size 256 115
	texture "i_journal" 40 90 256 152   40 0 256 62
        texture "i_journal"  216 154 256 210    0 6 40  62

        texture "i_journal"  221 211 256 255    0 66 35  110

	texture "i_help"  35 56 256 109 35 62 256 115
	texture "i_help"  0 56 35 60 0 62 35 66
      }

      sprite
      {
        name "close_focus"
        size 14 14
        texture "i_ctrls" 15 76 29 90 0 0 14 14
      }

      sprite
      {
        name "close_push"
        size 14 14
        texture "i_ctrls" 15 106 29 120 0 0 14 14
      }

      sprite
      {
        name "close_normal"
        size 14 14
        texture "i_ctrls" 15 91 29 105 0 0 14 14
      }

      sprite
      {
        name "help_focus"
        size 14 14
        texture "i_ctrls" 0 76 14 90 0 0 14 14
      }

      sprite
      {
        name "help_push"
        size 14 14
        texture "i_ctrls" 0 106 14 120 0 0 14 14
      }

      sprite
      {
        name "help_normal"
        size 14 14
        texture "i_ctrls" 0 91 14 105 0 0 14 14
      }

      sprite
      {
	name "sc_polzun"
	size 24 26
	texture "i_ctrls"  38 0 62 26 0 0 24 26
      }

      sprite
      {
	name "sc_lbfocus"
	size 18 18
	texture "i_ctrls"  38 27 56 45 0 0 18 18
      }

      sprite
      {
	name "sc_lbpush"
	size 18 18
	texture "i_ctrls"  57 50 75 68 0 0 18 18
      }

      sprite
      {
	name "sc_lbdis"
	size 18 18
	texture "i_ctrls"  44 88 62 106 0 0 18 18
      }

      sprite
      {
	name "sc_rbfocus"
	size 18 18
	texture "i_ctrls"  38 46 56 64 0 0 18 18
      }

      sprite
      {
	name "sc_rbpush"
	size 18 18
	texture "i_ctrls"  76 50 94 68 0 0 18 18
      }

      sprite
      {
	name "sc_rbdis"
	size 18 18
	texture "i_ctrls"  44 107 62 125 0 0 18 18
      }
   }

   windowName  "chat_sys"
   windowText  UISTR_WT_SYSMSG
   showTitle   4 0
   drawMethod  SPRITE "cont_window"
   position    0 0
   size        256 115
//   showEffect  ALPHA_IN   0.25
//   hideEffect  ALPHA_OUT  0.25
   font        3
   rectTitle   10 10 210 29
   alignWin    CENTER_X
   textcolor   237 208 161
   saveLastPosition true
   escapeHandle false
   canNotCross  true

   control                                       // id = 1
   {
     classID       TEXTLIST
     position      15 35
     size          200 67

     font          2

     chatlike      true
     formatstrings true
     maxitems      64

     scrollbar
     {
      classID	 SCROLL_BAR
      position	 209 16
      size	 16 33
      scrollSpr  "sc_polzun" 24 26
      deltaStep  10

      leftbutton
      {
       position   -1 -18
       size	  18 18
       drawMethod SPRITE

       focusedImage "sc_lbfocus"
       checkedImage "sc_lbpush"
       disabledImage "sc_lbdis"
      }

      rightbutton
      {
       position   -1 32
       size	  18 18
       drawMethod SPRITE

       focusedImage "sc_rbfocus"
       checkedImage "sc_rbpush"
       disabledImage "sc_rbdis"
      }
    }
   }

   control                                       // id = 2
   {
     classID    BUTTON   
     position   225 12
     size       14 14
     drawMethod SPRITE
     buttonStyle SEND_QUIT

     checkedImage     "close_push"
     focusedImage     "close_focus"
     uncheckedImage   "close_normal"

     tooltip
     {
       toolstr UISTR_CLOSEW
     }
   }

