   windowName  "edittext"
   windowText  UISTR_WT_HELP
   showTitle   4 0
   drawMethod  SPRITE "cont_window"
   position    0 0
   size        256 275
   showEffect  ALPHA_IN   0.25
   hideEffect  ALPHA_OUT  0.25
   font        3
   rectTitle   10 10 210 29
   alignWin    CENTER_X | CENTER_Y
   textcolor   237 208 161
   saveLastPosition false
   escapeHandle TRUE

   control                                       // id = 1
   {
     classID       RICHEDIT
     position      17 58
     size          200 170
     font          4
     textcolor     200 200 200

     scrollbar
     {
      classID	 SCROLL_BAR
      position	 207 -7
      size	 16 193
      scrollSpr  "sc_polzun" 24 26
      deltaStep  10

      leftbutton
      {
       position   -1 -18
       size	  18 18
       drawMethod SPRITE

       focusedImage "sc_lbfocus"
       checkedImage "sc_lbpush"
       disabledImage "sc_lbdis"
      }

      rightbutton
      {
       position   -1 192
       size	  18 18
       drawMethod SPRITE

       focusedImage "sc_rbfocus"
       checkedImage "sc_rbpush"
       disabledImage "sc_rbdis"
      }
    }
   }

   control                                       // id = 2
   {
     classID    BUTTON   
     position   225 12
     size       14 14
     drawMethod SPRITE
     buttonStyle SEND_QUIT

     checkedImage     "close_push"
     focusedImage     "close_focus"
     uncheckedImage   "close_normal"

     tooltip
     {
       toolstr UISTR_CLOSEW
     }
   }

   control					    // id = 3
   {
     classID	BUTTON
     position	100 235
     size	32 24
     drawMethod SPRITE
     uncheckedImage "ok_normal"
     checkedImage   "ok_push"
     focusedImage   "ok_focus"
     hotKey     "ENTER" 0 0 0
   }

   control					    // id = 4
   {
     classID	BUTTON
     position	134 235
     size	32 24
     drawMethod SPRITE
     buttonStyle SEND_QUIT
     uncheckedImage "cancel_normal"
     checkedImage   "cancel_push"
     focusedImage   "cancel_focus"
   }

 }


