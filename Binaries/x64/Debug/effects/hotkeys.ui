//----------------------------------------------------------------------------------
// Window: Hot keys big
//----------------------------------------------------------------------------------

 windowUI
 {
   spritesDef
   {
      sprite
      {
        name "h_window"
        size 205 185
	texture "i_mantra"  0 143 205 256  0 0 205 113
        texture "i_invent"  0 149 205 221  0 113 205 185
      }

      sprite
      {
        name "slot_simple"
        size 36 35
	texture "i_invent"  220 175 256 210 0 0 36 35
      }

      sprite
      {
        name "slot_simpleborder"
        size 36 35
	texture "i_invent"  36 221 72 256 0 0 36 35
      }

      sprite
      {
        name "close_focus"
        size 14 14
        texture "i_invent" 242 212 256 226 0 0 14 14
      }

      sprite
      {
        name "close_push"
        size 14 14
        texture "i_invent" 242 242 256 256 0 0 14 14
      }

      sprite
      {
        name "close_normal"
        size 14 14
        texture "i_invent" 242 227 256 241 0 0 14 14
      }

      sprite
      {
        name "help_focus"
        size 14 14
        texture "i_invent" 227 212 241 226 0 0 14 14
      }

      sprite
      {
        name "help_push"
        size 14 14
        texture "i_invent" 227 242 241 256 0 0 14 14
      }

      sprite
      {
        name "help_normal"
        size 14 14
        texture "i_invent" 227 227 241 241 0 0 14 14
      }

   }

   windowName  "hotkeys"
   windowText  UISTR_WT_HOTKEYS
   showTitle   3 -1
   drawMethod  SPRITE "h_window"
   position    0 50
   size        205 185
   showEffect  ALPHA_IN   0.25
   hideEffect  ALPHA_OUT  0.25
   font        3
   rectTitle   10 12 165 29
   canDragDrop true
   textcolor   237 208 161
   escapeHandle TRUE

   control                                       // id = 1
   {
     classID    BUTTON   
     position   175 13
     size       14 14
     drawMethod SPRITE
     buttonStyle SEND_QUIT

     checkedImage     "close_push"
     focusedImage     "close_focus"
     uncheckedImage   "close_normal"

     tooltip
     {
       toolstr UISTR_CLOSEW
     }
   }

   control					// id = 2
   {
     classID	BUTTON
     position	160 13
     size	14 14
     drawMethod SPRITE
     buttonStyle SEND_HELP
     windowHelp  "language\hotkeys.hts"

     checkedImage     "help_push"
     focusedImage     "help_focus"
     uncheckedImage   "help_normal"

     tooltip
     {
       toolstr UISTR_HELP
     }
   }

