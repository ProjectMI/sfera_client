//=====================================================================
// Definition   : Нейтральный агент, голубой цвет
// Effect number: 521
//=====================================================================

effect_def
{
   effect_name   "nagent blue"
   effect_number 521
   effect_time   -1
   subeffects_num 1

   subeffect 0 EFF_PSYSTEM "spell1"

   sound_def
   {
     audio_file "sounds\mg_spell_neu.wav"
     min_distance 1.0
     max_distance 15.0
   }

   light_def
   {
     light_pos   0.0 -2.0 0.0
     light_color 160 160 1560 255
   }

}


psystem_def
{
  psystem_name      "spell1"
  particles_num     100
  psystem_flags     PS_TRANSLATEONLY | PS_NOHEAVYATTACH | PS_EMITONPOSCHANGE
  self_illumination 255

  emission_def
  {
     shape            EMITSHAPE_SPHERE
     randseed         -1
     radius           0.06
     emit_num         1.0
  }

  // particle born definition
  particleborn_def
  {
    lifetime          60.0
    lifetime_rf       30.0
  }

  // texture definition
  texture_def
  {
    numframes 4
    animspeed 0
    texture   "fx_bclouds"
    type      PS_TANIMCOORD
    frame 0  0.000 0.000 0.500 0.000 0.500 0.500 0.000 0.500
    frame 1  0.500 0.000 1.000 0.000 1.000 0.500 0.500 0.500
    frame 2  0.000 0.500 0.500 0.500 0.500 1.000 0.000 1.000
    frame 3  0.500 0.500 1.000 0.500 1.000 1.000 0.500 1.000
    blendmode PS_BLENDADD
  }

  particletracks_def
  {
     nsize_tracks        1
     ncolor_tracks       1

     size_track
     {
        track_num 0
        numkeys   1
       rkey  0  0.0  0.15 0.15
     }

     color_track
     {
        track_num 0
        numkeys   3
        key  0   0.0 100  150  250 0
        key  1   0.1 100  150  250 100
        key  2   1.0 100  150  250 0
     }
  }

  particles_def
  {
     select all
     size_track     0
     color_track    0
     texture RANDOM
  }
}




