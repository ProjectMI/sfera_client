   }

   windowName  "mapbook"
   windowText  UISTR_WT_MAPBK
   showTitle   4 -1
   drawMethod  SPRITE "map_window"
   position    0 200
   size        205 152
   showEffect  ALPHA_IN   0.25
   hideEffect  ALPHA_OUT  0.25
   font        3
   rectTitle   10 12 165 29
   alignWin    RIGHT_X
   canDragDrop true
   textcolor   237 208 161
   escapeHandle TRUE

   control                                       // id = 1
   {
     classID    BUTTON   
     position   175 14
     size       14 14
     drawMethod SPRITE
     buttonStyle SEND_QUIT

     checkedImage     "close_push"
     focusedImage     "close_focus"
     uncheckedImage   "close_normal"

     tooltip
     {
       toolstr UISTR_CLOSEW
     }
   }

   control					// id = 2
   {
     classID	BUTTON
     position	160 14
     size	14 14
     drawMethod SPRITE
     buttonStyle SEND_HELP
     windowHelp  "language\mapbook.hts"

     checkedImage     "help_push"
     focusedImage     "help_focus"
     uncheckedImage   "help_normal"

     tooltip
     {
       toolstr UISTR_HELP
     }
   }

   control				       // id = 3
   {
     classID LISTITEM
     position 16 35
     size     155 102
     canDragDrop true
//     createitems 4

     itemTemplate
     {
       size 151 19
       drawMethod NONE
       canDragDrop true

       control
       {
	 classID    IMAGE
	 position   0 0
	 size	    151 18
         image      "slot_img"
       }

       control                                 // listID = 2 - map image
       {
	 classID    IMAGE
	 position   3 3
	 size	    12 12
       }

      control
      {
         classID    SLOT                       // listID = 3 - slot
         position   20 0
         size       131 18
         showTitle  0 0
         textformat CENTER_Y
         textofs    5 0
      }
     }

     vscrollbar
     {
      classID	 SCROLL_BAR
      position	 158 19
      size	 16 65
      scrollSpr  "sc_polzun" 24 26
      deltaStep  10

      leftbutton
      {
       position   -1 -18
       size	  18 18
       drawMethod SPRITE

       focusedImage "sc_lbfocus"
       checkedImage "sc_lbpush"
       disabledImage "sc_lbdis"
      }

      rightbutton
      {
       position   -1 64
       size	  18 18
       drawMethod SPRITE

       focusedImage "sc_rbfocus"
       checkedImage "sc_rbpush"
       disabledImage "sc_rbdis"
      }
    }
   }
 }
